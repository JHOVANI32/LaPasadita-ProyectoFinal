@{
    ViewData["Title"] = "Crear Producto - Admin";
}

<div class="min-h-screen bg-gray-100 py-8">
    <div class="container mx-auto px-4 max-w-2xl">
        
        <!-- Header -->
        <div class="mb-8">
            <a href="/Productos" class="text-green-600 hover:text-green-700 flex items-center gap-2 mb-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Volver al catálogo
            </a>
            <h1 class="text-3xl font-bold text-gray-800">Crear Nuevo Producto</h1>
            <p class="text-gray-500 mt-2">Complete el formulario para agregar un producto al inventario</p>
        </div>

        <!-- Formulario -->
        <div class="bg-white rounded-2xl shadow-lg p-8">
            <form id="crearProductoForm" class="space-y-6">
                
                <!-- Nombre -->
                <div>
                    <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">
                        Nombre del Producto *
                    </label>
                    <input type="text" id="nombre" name="nombre" required
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                           placeholder="Ej: Arroz La Merced 1kg">
                </div>

                <!-- Descripción -->
                <div>
                    <label for="descripcion" class="block text-sm font-medium text-gray-700 mb-2">
                        Descripción
                    </label>
                    <textarea id="descripcion" name="descripcion" rows="3"
                              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                              placeholder="Descripción detallada del producto"></textarea>
                </div>

                <!-- Precio y Oferta -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="precio" class="block text-sm font-medium text-gray-700 mb-2">
                            Precio *
                        </label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500">$</span>
                            <input type="number" id="precio" name="precio" step="0.01" min="0" required
                                   class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                   placeholder="0.00">
                        </div>
                    </div>
                    <div>
                        <label for="precio_oferta" class="block text-sm font-medium text-gray-700 mb-2">
                            Precio Oferta
                        </label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500">$</span>
                            <input type="number" id="precio_oferta" name="precio_oferta" step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                   placeholder="0.00">
                        </div>
                    </div>
                </div>

                <!-- Categoría -->
                <div>
                    <label for="categoria_id" class="block text-sm font-medium text-gray-700 mb-2">
                        Categoría *
                    </label>
                    <select id="categoria_id" name="categoria_id" required
                            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all">
                        <option value="">Seleccione una categoría</option>
                        @if (ViewBag.Categorias != null)
                        {
                            foreach (var cat in ViewBag.Categorias as List<CategoriaDTO>)
                            {
                                <option value="@cat.id">@cat.nombre</option>
                            }
                        }
                    </select>
                </div>

                <!-- Marca y Unidad -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="marca" class="block text-sm font-medium text-gray-700 mb-2">
                            Marca
                        </label>
                        <input type="text" id="marca" name="marca"
                               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                               placeholder="Ej: Nestlé">
                    </div>
                    <div>
                        <label for="unidad_medida" class="block text-sm font-medium text-gray-700 mb-2">
                            Unidad de Medida
                        </label>
                        <select id="unidad_medida" name="unidad_medida"
                                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all">
                            <option value="Pieza">Pieza</option>
                            <option value="Kilogramo">Kilogramo</option>
                            <option value="Litro">Litro</option>
                            <option value="Paquete">Paquete</option>
                            <option value="Botella">Botella</option>
                            <option value="Bolsa">Bolsa</option>
                        </select>
                    </div>
                </div>

                <!-- Código de Barras -->
                <div>
                    <label for="codigo_barras" class="block text-sm font-medium text-gray-700 mb-2">
                        Código de Barras
                    </label>
                    <input type="text" id="codigo_barras" name="codigo_barras"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                           placeholder="7501234567890">
                </div>

                <!-- URL de Imagen -->
                <div>
                    <label for="imagen_url" class="block text-sm font-medium text-gray-700 mb-2">
                        URL de Imagen
                    </label>
                    <input type="url" id="imagen_url" name="imagen_url"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                           placeholder="https://ejemplo.com/imagen.jpg">
                </div>

                <!-- Mensaje de estado -->
                <div id="mensajeEstado" class="hidden p-4 rounded-xl"></div>

                <!-- Botones -->
                <div class="flex gap-4 pt-4">
                    <button type="submit"
                            class="flex-1 bg-green-600 text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition-colors flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Guardar Producto
                    </button>
                    <a href="/Productos" 
                       class="px-8 py-3 border border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-colors">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('crearProductoForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = {
            nombre: document.getElementById('nombre').value,
            descripcion: document.getElementById('descripcion').value || null,
            precio: parseFloat(document.getElementById('precio').value),
            precio_oferta: document.getElementById('precio_oferta').value ? 
                          parseFloat(document.getElementById('precio_oferta').value) : null,
            categoria_id: parseInt(document.getElementById('categoria_id').value),
            marca: document.getElementById('marca').value || null,
            unidad_medida: document.getElementById('unidad_medida').value,
            codigo_barras: document.getElementById('codigo_barras').value || null,
            imagen_url: document.getElementById('imagen_url').value || null,
            activo: true
        };

        const mensajeDiv = document.getElementById('mensajeEstado');
        
        try {
            const response = await fetch('/api/productos', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (result.success) {
                mensajeDiv.className = 'p-4 rounded-xl bg-green-100 text-green-700';
                mensajeDiv.textContent = 'Producto creado exitosamente. Redirigiendo...';
                mensajeDiv.classList.remove('hidden');
                
                setTimeout(() => {
                    window.location.href = '/Productos';
                }, 1500);
            } else {
                mensajeDiv.className = 'p-4 rounded-xl bg-red-100 text-red-700';
                mensajeDiv.textContent = result.message || 'Error al crear el producto';
                mensajeDiv.classList.remove('hidden');
            }
        } catch (error) {
            mensajeDiv.className = 'p-4 rounded-xl bg-red-100 text-red-700';
            mensajeDiv.textContent = 'Error de conexión con el servidor';
            mensajeDiv.classList.remove('hidden');
        }
    });
</script>
}
